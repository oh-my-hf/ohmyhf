{
  "name": "oh-my-huggingface-desktop",
  "version": "0.0.7",
  "private": true,
  "description": "Oh My HuggingFace — unofficial desktop client for the Hugging Face Hub",
  "license": "Apache-2.0",
  "author": "Oh My HuggingFace contributors",
  "homepage": "https://github.com/oh-my-hf/ohmyhf",
  "main": "./out/main/index.mjs",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit --composite false -p tsconfig.node.json && tsc --noEmit --composite false -p tsconfig.web.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "electron-vite build && playwright test",
    "test:e2e:packaged": "playwright test --config playwright.packaged.config.ts",
    "test:screenshots": "CAPTURE_SCREENSHOTS=1 playwright test --config playwright.screenshots.config.ts",
    "i18n:extract": "i18next",
    "build:linux": "electron-vite build && electron-builder --linux",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:mac:release": "electron-vite build && electron-builder --mac -c.mac.identity=OhMyHF-Release",
    "build:win": "electron-vite build && electron-builder --win"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "electron-updater": "^6.8.9",
    "hyparquet": "^1.26.2",
    "ignore": "^5.3.2"
  },
  "devDependencies": {
    "@fontsource-variable/noto-sans-sc": "^5.2.10",
    "@fontsource-variable/source-sans-3": "^5.2.9",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@oh-my-huggingface/hub-api": "workspace:*",
    "@oh-my-huggingface/shared": "workspace:*",
    "@playwright/test": "^1.61.1",
    "@shikijs/core": "^4.3.1",
    "@shikijs/engine-javascript": "^4.3.1",
    "@shikijs/langs": "^4.3.1",
    "@shikijs/themes": "^4.3.1",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-scroll-area": "^1.2.14",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-virtual": "^3.14.5",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "apache-arrow": "^21.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "hyllama": "^0.2.2",
    "i18next": "^26.3.5",
    "i18next-parser": "^9.4.0",
    "lucide-react": "^1.23.0",
    "onnx-proto": "^8.0.1",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "react-router": "^8.2.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~5.9.3",
    "vitest": "^4.1.10",
    "zustand": "^5.0.14"
  }
}
